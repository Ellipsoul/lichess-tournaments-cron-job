# Create a Lichess personal access token with the `tournament:write` scope.
LICHESS_API_TOKEN=lip_replace_me

# The Lichess team ID to use when joining a team battle. It is the final part
# of the team URL, e.g. https://lichess.org/team/example-team -> example-team.
LICHESS_TEAM_ID=your-team-id

# Set true to list matching tournaments without joining them.
# DRY_RUN=true
